rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: This ruleset implements a strict user-ownership security model. All primary
     * business data, including clients, legal processes, and documents, is segregated into private
     * user-specific data trees. Access to any document within a user's tree is restricted exclusively
     * to that authenticated user.
     *
     * Data Structure: The data is hierarchically organized under `/users/{userId}`. This path-based
     * ownership model ensures that queries for a user's data are inherently secure. A separate
     * top-level collection, `/tags`, is used for global, read-only data available to all users.
     *
     * Key Security Decisions:
     * - Default Deny: All access is denied unless explicitly granted.
     * - Strict Ownership: A user can only access data where the path's `{userId}` matches their
     *   authentication UID. Cross-user access is forbidden.
     * - No User Listing: It is not possible to list documents in the top-level `/users` collection.
     * - Relational Integrity: On creation, documents must contain fields that link back to their
     *   parent documents in the path (e.g., a Document must contain the correct `legalProcessId`
     *   and `clientId`), enforcing data consistency. These relational fields are immutable.
     *
     * Denormalization for Authorization: To ensure fast and simple authorization checks, key
     * ownership and relational identifiers (e.g., `createdBy`, `clientId`, `legalProcessId`) are
     * denormalized directly onto the documents being secured. This avoids slow and costly `get()`
     * calls in security rules, making the system more performant and secure. For example, a rule
     * on a Document can validate its `uploadedBy` and `clientId` fields directly without needing
     * to fetch the parent LegalProcess or Client documents.
     *
     * Structural Segregation: User-private data (`/users/{userId}/...`) is kept entirely separate
     * from globally accessible data (`/tags`). This clear separation allows for distinct and simple
     * security rules for each collection type, enhancing security for list operations and making
     * the ruleset easier to maintain.
     */

    // --------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------

    /**
     * @description Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the currently authenticated user's ID matches the provided userId.
     * @param userId The user ID to check against the authenticated user.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner and the document already exists.
     *              Used for safe update and delete operations.
     * @param userId The user ID to check for ownership.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Validates the integrity of a new User document on creation.
     */
    function isValidNewUser(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * @description Ensures critical relational fields of a User document are immutable.
     */
    function isUserUpdateValid() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * @description Validates the integrity of a new Client document on creation.
     */
    function isValidNewClient(userId) {
      return request.resource.data.createdBy == userId;
    }
    
    /**
     * @description Ensures critical relational fields of a Client document are immutable.
     */
    function isClientUpdateValid() {
      return request.resource.data.createdBy == resource.data.createdBy;
    }
    
    /**
     * @description Validates the integrity of a new LegalProcess document on creation.
     */
    function isValidNewLegalProcess(userId, clientId) {
      let data = request.resource.data;
      return data.createdBy == userId
          && data.responsibleUserId == userId
          && data.clientId == clientId;
    }
    
    /**
     * @description Ensures critical relational fields of a LegalProcess document are immutable.
     */
    function isLegalProcessUpdateValid() {
      let incoming = request.resource.data;
      let existing = resource.data;
      return incoming.createdBy == existing.createdBy
          && incoming.responsibleUserId == existing.responsibleUserId
          && incoming.clientId == existing.clientId;
    }
    
    /**
     * @description Validates the integrity of a new Document on creation.
     */
    function isValidNewDocument(userId, clientId, legalProcessId) {
      let data = request.resource.data;
      return data.uploadedBy == userId
          && data.clientId == clientId
          && data.legalProcessId == legalProcessId;
    }
    
    /**
     * @description Ensures critical relational fields of a Document are immutable.
     */
    function isDocumentUpdateValid() {
      let incoming = request.resource.data;
      let existing = resource.data;
      return incoming.uploadedBy == existing.uploadedBy
          && incoming.clientId == existing.clientId
          && incoming.legalProcessId == existing.legalProcessId;
    }

    /**
     * @description Validates the integrity of a new Deadline document on creation.
     */
    function isValidNewDeadline(userId, clientId, legalProcessId) {
      let data = request.resource.data;
      return data.createdBy == userId
          && data.clientId == clientId
          && data.legalProcessId == legalProcessId;
    }
    
    /**
     * @description Ensures critical relational fields of a Deadline document are immutable.
     */
    function isDeadlineUpdateValid() {
      let incoming = request.resource.data;
      let existing = resource.data;
      return incoming.createdBy == existing.createdBy
          && incoming.clientId == existing.clientId
          && incoming.legalProcessId == existing.legalProcessId;
    }
    
    /**
     * @description Validates the integrity of a new Alert document on creation.
     */
    function isValidNewAlert(userId) {
      return request.resource.data.userId == userId;
    }
    
    /**
     * @description Ensures critical relational fields of an Alert document are immutable.
     */
    function isAlertUpdateValid() {
      return request.resource.data.userId == resource.data.userId;
    }

    // --------------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------------

    /**
     * @description Manages user profile data. A user can create their own profile,
     *              and can only read or write to their own document.
     * @path /users/{userId}
     * @allow (create) An authenticated user with UID 'user123' creating their own profile at `/users/user123`.
     * @deny (get) A user 'user123' trying to read the profile of 'user456' at `/users/user456`.
     * @principle Restricts access to a user's own data tree and allows self-creation of a profile.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Disallow listing all users for security.
      allow create: if isOwner(userId) && isValidNewUser(userId);
      allow update: if isExistingOwner(userId) && isUserUpdateValid();
      allow delete: if isExistingOwner(userId);

      /**
       * @description Manages client records owned by a specific user. Only the owning
       *              user can access or manage these records.
       * @path /users/{userId}/clients/{clientId}
       * @allow (list) User 'user123' listing their own clients at `/users/user123/clients`.
       * @deny (update) User 'user456' trying to update a client at `/users/user123/clients/clientABC`.
       * @principle Enforces document ownership within a private user data tree.
       */
      match /clients/{clientId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidNewClient(userId);
        allow update: if isExistingOwner(userId) && isClientUpdateValid();
        allow delete: if isExistingOwner(userId);

        /**
         * @description Manages legal processes for a specific client, owned by a user.
         *              Access is restricted to the owning user.
         * @path /users/{userId}/clients/{clientId}/legalProcesses/{legalProcessId}
         * @allow (create) User 'user123' creating a new process for their client at `.../legalProcesses/procXYZ`.
         * @deny (get) User 'user456' trying to read a process at `/users/user123/clients/clientABC/legalProcesses/procXYZ`.
         * @principle Enforces strict ownership and validates relational integrity with parent documents.
         */
        match /legalProcesses/{legalProcessId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) && isValidNewLegalProcess(userId, clientId);
          allow update: if isExistingOwner(userId) && isLegalProcessUpdateValid();
          allow delete: if isExistingOwner(userId);

          /**
           * @description Manages documents related to a specific legal process. Only the
           *              owning user can manage these documents.
           * @path /users/{userId}/clients/{clientId}/legalProcesses/{legalProcessId}/documents/{documentId}
           * @allow (delete) User 'user123' deleting their own document at `.../documents/docABC`.
           * @deny (create) User 'user123' trying to create a document with a mismatched `clientId`.
           * @principle Enforces strict ownership and validates relational integrity with parent documents in the path.
           */
          match /documents/{documentId} {
            allow get: if isOwner(userId);
            allow list: if isOwner(userId);
            allow create: if isOwner(userId) && isValidNewDocument(userId, clientId, legalProcessId);
            allow update: if isExistingOwner(userId) && isDocumentUpdateValid();
            allow delete: if isExistingOwner(userId);
          }

          /**
           * @description Manages deadlines for a legal process. Access is restricted to the
           *              user who owns the parent legal process.
           * @path /users/{userId}/clients/{clientId}/legalProcesses/{legalProcessId}/deadlines/{deadlineId}
           * @allow (list) User 'user123' listing deadlines for their own process at `.../deadlines`.
           * @deny (update) User 'user456' trying to update a deadline for a process owned by 'user123'.
           * @principle Enforces strict ownership and validates denormalized relational IDs for fast authorization.
           */
          match /deadlines/{deadlineId} {
            allow get: if isOwner(userId);
            allow list: if isOwner(userId);
            allow create: if isOwner(userId) && isValidNewDeadline(userId, clientId, legalProcessId);
            allow update: if isExistingOwner(userId) && isDeadlineUpdateValid();
            allow delete: if isExistingOwner(userId);
          }
        }
      }

      /**
       * @description Manages AI-generated alerts for a specific user. Alerts are private
       *              and can only be accessed by the intended recipient.
       * @path /users/{userId}/alerts/{alertId}
       * @allow (get) User 'user123' reading their own alert at `/users/user123/alerts/alertABC`.
       * @deny (list) User 'user456' trying to list alerts at `/users/user123/alerts`.
       * @principle Restricts access to a user's own data, ensuring privacy of alerts.
       */
      match /alerts/{alertId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidNewAlert(userId);
        allow update: if isExistingOwner(userId) && isAlertUpdateValid();
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Provides a global dictionary of tags. All authenticated users can read
     *              tags, but writing is restricted to prevent unauthorized modifications.
     * @path /tags/{tagId}
     * @allow (get) Any authenticated user reading a tag at `/tags/tagABC`.
     * @deny (create) Any non-admin user trying to create a new tag.
     * @principle Allows public read access for signed-in users while protecting the collection from writes. Admin-only writes can be added later.
     */
    match /tags/{tagId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      // Write operations are disabled. Enable them for admin roles by checking a user's custom claims or role field.
      // Example for admin-only writes: `get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'`
      allow create: if false; // TODO: Implement admin-only creation logic.
      allow update: if false; // TODO: Implement admin-only update logic.
      allow delete: if false; // TODO: Implement admin-only deletion logic.
    }
  }
}