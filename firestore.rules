rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra geral: permite escrita apenas para usuários autenticados.
    match /{document=**} {
      allow write: if request.auth != null;
    }

    // Permite que qualquer pessoa leia as coleções principais
    match /clients/{clientId} {
      allow get: if true;
    }
    match /clients {
      allow list: if true;
    }

    match /processes/{processId} {
      allow get: if true;
    }
    match /processes {
      allow list: if true;
    }

    match /events/{eventId} {
      allow get: if true;
    }
    match /events {
      allow list: if true;
    }

    match /documents/{documentId} {
      allow get: if true;
    }
    match /documents {
      allow list: if true;
    }
    
    match /documentTemplates/{templateId} {
      allow get: if true;
    }
    match /documentTemplates {
      allow list: if true;
    }

    match /notepad/{docId} {
       allow read, write: if request.auth != null;
    }
  }
}
